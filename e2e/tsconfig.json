{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@fixtures/*": ["./fixtures/*"],
      "@pages/*": ["./fixtures/pages/*"]
    }
  },
  "include": ["specs/**/*.ts", "fixtures/**/*.ts", "playwright.config.ts"]
}
